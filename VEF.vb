Class Polyhedron
Module VEFString
CONST V - E + F = 2
V = Vertice,E = Edge,F = Face
Structure Tetrahedron
      4 - 6 + 4 = 2
end Structure
Structure Hexahedron
      6 - 12 + 8 = 2
end Structure
Structure Octahedron
      8 - 12 + 6 = 2
end Structure
Structure Dodecahedron
      12 - 30 + 20 = 2
end Structure
Structure Icosahedron
      20 - 30 + 12 = 2
end Structure 
End Module  
End Class